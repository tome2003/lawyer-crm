# Public site URL (no trailing slash). Used for Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Recurring monthly Price IDs (Products → your plan → Pricing → Price ID)
# Create three subscription prices in Stripe and paste each `price_...` id:
STRIPE_PRICE_SOLO=price_
STRIPE_PRICE_GROWTH=price_
STRIPE_PRICE_FIRM=price_

# Optional: webhook signing secret for production billing events
# STRIPE_WEBHOOK_SECRET=whsec_...
